# Copy to .env and fill in locally. Never commit .env to git.

# Client (Vite — exposed to browser, no secrets)
VITE_APP_NAME=World Cup Pool 2026
VITE_FLAG_CDN_BASE=https://flagcdn.com/w40
VITE_USE_MOCK=true

# Server-only (Netlify Functions — set in Netlify dashboard for production)
# NETLIFY_DB_URL is auto-injected by Netlify Database; do not hardcode.
ODDS_API_KEY=

# Optional: admin operations (comma-separated Identity user IDs)
ADMIN_USER_IDS=

# Node environment
NODE_ENV=development
