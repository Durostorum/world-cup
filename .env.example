# Copy to .env and fill in locally. Never commit .env to git.

# ── Local full stack (npm run dev:local → http://localhost:8888) ──────────────
VITE_USE_MOCK=false
# VITE_ENABLE_DEMO_AUTH=true       # optional: auto-login as demo user without Identity
# VITE_DEMO_USER_ID=00000000-0000-4000-8000-000000000001

# ── UI-only mock mode (npm run dev → http://localhost:5173) ───────────────────
# VITE_USE_MOCK=true

# Client (Vite — exposed to browser, no secrets)
VITE_APP_NAME=World Cup Pool 2026
VITE_FLAG_CDN_BASE=https://flagcdn.com/w40

# Server-only (Netlify Functions — set in Netlify dashboard for production)
# NETLIFY_DB_URL is auto-injected by netlify dev / deploy; do not hardcode.

# ODDS_API_KEY: Get a free API key from https://the-odds-api.com
# Sign up for an account, then add the key in Netlify dashboard: Site settings > Environment variables
ODDS_API_KEY=

# Comma-separated extra CORS origins (URL / DEPLOY_PRIME_URL are added automatically)
ALLOWED_ORIGINS=

# Comma-separated admin emails (Identity login emails) for protected admin API routes
ADMIN_EMAILS=

# Legacy alias — prefer ADMIN_EMAILS
# ADMIN_USER_IDS=

# Node environment
NODE_ENV=development

# Do NOT set DATABASE_URL for Netlify local dev — it overrides the embedded DB and
# causes ECONNREFUSED if you don't run your own Postgres on localhost:5432.
# NETLIFY_DB_URL is injected automatically by `netlify dev` / `netlify dev:exec`.
# DATABASE_URL=

# ── WHERE TO SET PRODUCTION VARIABLES ────────────────────────────────────────
# For Netlify deployment, set these in:
# 1. Go to your Netlify dashboard
# 2. Navigate to Site settings > Environment variables
# 3. Add the following variables:
#    - ODDS_API_KEY (from https://the-odds-api.com)
#    - ALLOWED_ORIGINS (optional, comma-separated URLs)
#    - ADMIN_EMAILS (comma-separated admin login emails for /api/admin/* routes)
# Note: NETLIFY_DB_URL is automatically injected by Netlify, do not set it manually.