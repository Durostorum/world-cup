    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "0.31.10",
    "eslint": "^9.17.0",
    "netlify-cli": "^26.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "puppeteer": "^24.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.7.0",
